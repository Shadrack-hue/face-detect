    <!-- MediaPipe scripts optimized for browser compatibility and Vercel -->
    <script src="https://jsdelivr.net" crossorigin="anonymous"></script>
    <script src="https://jsdelivr.net" crossorigin="anonymous"></script>

    <script>
        const video = document.getElementById("video");
        const canvas = document.getElementById("canvas");
        const ctx = canvas.getContext("2d");
        const statusBox = document.getElementById("status");

        function setStatus(message, type = "loading") {
            statusBox.className = `status ${type}`;
            statusBox.textContent = message;
            console.log(message);
        }

        async function initialize() {
            try {
                setStatus("Loading AI model...", "loading");
                
                // Stable model usage from JSDelivr CDN
                const faceDetection = new FaceDetection({
                    locateFile: (file) => `https://jsdelivr.net{file}`
                });

                faceDetection.setOptions({
                    model: "short",
                    minDetectionConfidence: 0.6
                });

                faceDetection.onResults(onResults);

                setStatus("Requesting webcam access...", "loading");
                
                // Camera setup compatible with mobile and desktop
                const stream = await navigator.mediaDevices.getUserMedia({
                    video: { 
                        width: { ideal: 1280 }, 
                        height: { ideal: 720 },
                        facingMode: "user"
                    }
                });
                
                video.srcObject = stream;
                
                // Ensure video dimensions are fully loaded before rendering
                await new Promise((resolve) => {
                    video.onloadedmetadata = () => {
                        adjustCanvasSize();
                        resolve();
                    };
                });

                await video.play();
                setStatus("Webcam active. Detecting faces...", "success");

                // Initialize MediaPipe Camera Loop
                const camera = new Camera(video, {
                    onFrame: async () => {
                        await faceDetection.send({ image: video });
                    },
                    width: video.videoWidth,
                    height: video.videoHeight
                });
                
                camera.start();

                // Adjust dimensions when window is resized
                window.addEventListener('resize', adjustCanvasSize);

            } catch (error) {
                console.error("Attention:", error);
                setStatus("Error: Webcam or AI model could not be initialized.", "error");
            }
        }

        function adjustCanvasSize() {
            canvas.width = video.videoWidth || 640;
            canvas.height = video.videoHeight || 480;
        }

        function onResults(results) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            if (!results.detections || results.detections.length === 0) return;

            results.detections.forEach((detection) => {
                const box = detection.boundingBox;
                
                // Convert MediaPipe normalized coordinates (0 to 1) to actual canvas pixels
                const x = (box.xCenter - box.width / 2) * canvas.width;
                const y = (box.yCenter - box.height / 2) * canvas.height;
                const width = box.width * canvas.width;
                const height = box.height * canvas.height;

                // Draw face bounding box
                ctx.strokeStyle = "#00ff88";
                ctx.lineWidth = 4;
                ctx.strokeRect(x, y, width, height);

                // Draw confidence score percentage
                ctx.fillStyle = "#00ff88";
                ctx.font = "bold 16px Inter, sans-serif";
                const scorePercentage = (detection.score ? detection.score : detection.score) * 100;
                ctx.fillText(
                    `Face: ${scorePercentage.toFixed(0)}%`,
                    x,
                    y - 12
                );
            });
        }

        // Start initialization after full page load
        window.addEventListener("load", initialize);
    </script>
</body>
